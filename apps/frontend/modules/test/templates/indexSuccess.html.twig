{# apps/frontend/modules/test/templates/indexSuccess.html.twig #}

<div class="container mt-4">
  <div class="card shadow">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
      <div>
        <h3 class="mb-0"><i class="fas fa-hospital-symbol me-2"></i>Monitoreo de Salud Global</h3>
        <small class="text-white-50">Visualizando {{ pager.getNbResults() }} países registrados</small>
      </div>
      <div class="btn-group">
        <a href="/frontend_dev.php/test/sincronizar" class="btn btn-sm btn-light shadow-sm">
          <i class="fas fa-sync-alt me-1"></i> Sincronizar API
        </a>
        <a href="/frontend_dev.php/alerta/new" class="btn btn-sm btn-warning shadow-sm">
          <i class="fas fa-plus me-1"></i> Crear Alerta
        </a>
      </div>
    </div>

    <div class="card-body p-0">
      <table class="table table-hover table-striped mb-0">
        <thead class="table-dark">
          <tr>
            <th class="ps-4">Continente</th>
            <th>País</th>
            <th class="text-center">Datos (Casos / Muertes)</th>
            <th class="text-center">Estado de Alerta</th>
            <th class="text-center">ISO</th>
            <th class="pe-4 text-end">Gestión</th>
          </tr>
        </thead>
        <tbody>
          {# Iteramos sobre los resultados del Paginador #}
          {% for pais in pager.getResults() %}
            <tr>
              <td class="ps-4 align-middle">
                <span class="badge bg-info text-dark">{{ pais.Continente.nombre }}</span>
              </td>
              <td class="align-middle">
                <strong>{{ pais.nombre }}</strong>
              </td>
              <td class="text-center align-middle">
                <div class="small">
                  <span class="d-block text-primary"><strong>Casos:</strong> {{ pais.casos_totales|number_format }}</span>
                  <span class="d-block text-danger"><strong>Muertes:</strong> {{ pais.muertes|number_format }}</span>
                </div>
              </td>
              <td class="text-center align-middle">
                {# Verificamos si existen alertas en la tabla relacionada #}
                {% if pais.AlertaMedica|length > 0 %}
                  <span class="badge bg-danger animate-pulse">
                    <i class="fas fa-exclamation-circle me-1"></i> {{ pais.AlertaMedica|length }} ALERTA(S)
                  </span>
                {% else %}
                  <span class="text-muted small italic text-secondary">Sin alertas registradas</span>
                {% endif %}
              </td>
              <td class="text-center align-middle">
                <span class="badge border text-dark bg-light">{{ pais.codigo_iso }}</span>
              </td>
              <td class="pe-4 text-end align-middle">
                <div class="btn-group btn-group-sm">
                  <a href="/frontend_dev.php/pais/{{ pais.id }}" class="btn btn-outline-primary" title="Ver Detalle">
                    <i class="fas fa-eye"></i>
                  </a>
                  <a href="/frontend_dev.php/alerta/new?pais_id={{ pais.id }}" class="btn btn-outline-warning" title="Agregar Alerta">
                    <i class="fas fa-plus"></i>
                  </a>
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="6" class="text-center py-5">
                <div class="text-muted">
                  <i class="fas fa-database fa-3x mb-3"></i>
                  <p class="mb-0">No se encontraron datos en la base de datos local.</p>
                  <small>Haz clic en "Sincronizar API" para importar la información.</small>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="card-footer bg-light">
      {% if pager.haveToPaginate() %}
        <nav aria-label="Paginación de salud">
          <ul class="pagination pagination-sm justify-content-center mb-0">
            {# Botón Anterior #}
            <li class="page-item {{ pager.getPage() == 1 ? 'disabled' : '' }}">
              <a class="page-link" href="/frontend_dev.php/test?page={{ pager.getPreviousPage() }}">
                <i class="fas fa-chevron-left"></i>
              </a>
            </li>

            {# Números de Página #}
            {% for page in pager.getLinks() %}
              <li class="page-item {{ page == pager.getPage() ? 'active' : '' }}">
                <a class="page-link" href="/frontend_dev.php/test?page={{ page }}">{{ page }}</a>
              </li>
            {% endfor %}

            {# Botón Siguiente #}
            <li class="page-item {{ pager.getPage() == pager.getLastPage() ? 'disabled' : '' }}">
              <a class="page-link" href="/frontend_dev.php/test?page={{ pager.getNextPage() }}">
                <i class="fas fa-chevron-right"></i>
              </a>
            </li>
          </ul>
        </nav>
        <div class="text-center mt-2">
          <small class="text-muted">Mostrando página {{ pager.getPage() }} de {{ pager.getLastPage() }}</small>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .animate-pulse {
    animation: pulse-red 2s infinite;
  }
  @keyframes pulse-red {
    0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4); }
    70% { box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); }
    100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
  }
  .table-hover tbody tr:hover {
    background-color: rgba(13, 110, 253, 0.05);
  }
</style>