{# apps/frontend/modules/test/templates/indexSuccess.html.twig #}

<div class="container mt-4">
  <div class="card shadow">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
      <div>
        <h3 class="mb-0"><i class="fas fa-hospital-symbol me-2"></i>Monitoreo de Salud Global</h3>
        <small class="text-white-50">Total de países: {{ paises|length }}</small>
      </div>
      <a href="/frontend_dev.php/test/sincronizar" class="btn btn-sm btn-light shadow-sm">
        <i class="fas fa-sync-alt me-1"></i> Actualizar desde API
      </a>
    </div>
    
    <div class="card-body p-0">
      <table class="table table-hover table-striped mb-0">
        <thead class="table-dark">
          <tr>
            <th class="ps-4">Continente</th>
            <th>País</th>
            <th class="text-center">Casos Totales</th>
            <th class="text-center">Muertes</th>
            <th class="text-center">ISO</th>
          </tr>
        </thead>
        <tbody>
  {% for pais in paises %}
    <tr>
      <td class="ps-4 align-middle">
        {% if pais.Continente %}
          <span class="badge bg-info text-dark">{{ pais.Continente.nombre }}</span>
        {% else %}
          <span class="badge bg-secondary">N/A</span>
        {% endif %}
      </td>
      <td class="align-middle"><strong>{{ pais.nombre }}</strong></td>
      <td class="text-center">{{ pais.casos_totales|number_format }}</td>
      <td class="text-center text-danger">{{ pais.muertes|number_format }}</td>
      <td class="text-center"><code>{{ pais.codigo_iso }}</code></td>
    </tr>
  {% else %}
    <tr>
      <td colspan="5" class="text-center py-5">
        <p>No hay datos. Dale a "Sincronizar API".</p>
      </td>
    </tr>
  {% endfor %}
</tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .table-hover tbody tr:hover {
    background-color: rgba(13, 110, 253, 0.05);
  }
  .fw-bold { font-weight: 700; }
</style>